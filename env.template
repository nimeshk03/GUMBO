# GUM Backend Security Configuration
# Copy this file to .env and update with your production values

# CORS Configuration
ALLOWED_ORIGINS=https://gumbo.app,https://www.gumbo.app,https://app.gumbo.app
ALLOWED_HOSTS=gumbo.app,*.gumbo.app,www.gumbo.app,app.gumbo.app
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Authorization,Content-Type
ALLOW_CREDENTIALS=false

# CORS Settings
CORS_MAX_AGE=86400
STRICT_CORS=true

# Compression
ENABLE_COMPRESSION=true

# AI Provider Configuration
TEXT_PROVIDER=azure  # or openai
VISION_PROVIDER=openrouter  # or azure

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name

# OpenAI Configuration (if using OpenAI instead of Azure)
OPENAI_API_KEY=your_openai_api_key

# OpenRouter Configuration (for vision)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Database Configuration
DATABASE_URL=sqlite:///gum.db

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS=100
RATE_LIMIT_DEFAULT_WINDOW=3600

# Logging
LOG_LEVEL=INFO

# API Authentication (required for protected endpoints)
API_AUTH_TOKEN=replace_with_strong_token

# Binding / Networking
BIND_HOST=127.0.0.1
BIND_PORT=8000

# API Documentation (disable in production)
ENABLE_API_DOCS=false

# Frontend server CORS (static server)
FRONTEND_ALLOWED_ORIGINS=http://localhost:3000

